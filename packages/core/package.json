{
  "name": "@futuremachine/core",
  "version": "0.1.1",
  "author": "Nathan Memmott <nathanmemmott@gmail.com>",
  "license": "ISC",
  "description": "A TypeScript library for Futures, persistent Promises that survive process restarts and can be resolved by ID.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/futuremachine-org/futuremachine.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/futuremachine-org/futuremachine/issues"
  },
  "homepage": "https://github.com/futuremachine-org/futuremachine",
  "keywords": [
    "persistent-promises",
    "futures",
    "typescript",
    "durable-execution",
    "resumable-workflows",
    "state-management",
    "async-persistence",
    "process-recovery",
    "long-running-tasks",
    "persistent-collections"
  ],
  "type": "module",
  "main": "out/src/index.js",
  "types": "out/src/index.d.ts",
  "files": [
    "out/src",
    "!out/src/**/*.map",
    "!out/src/**/*.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf out",
    "build": "tsc -b",
    "test": "tsc -b && node --test",
    "test:stryker": "node --test out/test/**/*.test.js"
  }
}
