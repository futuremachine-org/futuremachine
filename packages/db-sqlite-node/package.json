{
  "name": "@futuremachine/db-sqlite-node",
  "version": "0.1.0",
  "author": "Nathan Memmott <nathanmemmott@gmail.com>",
  "license": "ISC",
  "description": "The node:sqlite storage implementation for FutureMachine. Provides a persistent database backend for @futuremachine/core with on-demand garbage collection for unreachable Futures and containers.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/futuremachine-org/futuremachine.git",
    "directory": "packages/db-sqlite-node"
  },
  "bugs": {
    "url": "https://github.com/futuremachine-org/futuremachine/issues"
  },
  "homepage": "https://github.com/futuremachine-org/futuremachine",
  "keywords": [
    "sqlite",
    "sql",
    "persistence-layer",
    "futuremachine-adapter",
    "database-backend",
    "query-serialization",
    "disk-storage"
  ],
  "type": "module",
  "main": "out/src/sql_future_database.js",
  "types": "out/src/sql_future_database.d.ts",
  "files": [
    "out/src",
    "!out/src/**/*.map",
    "!out/src/**/*.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "tsc -b --clean",
    "build": "tsc -b",
    "test": "tsc -b && rimraf db && node --test --expose-gc",
    "test:stryker": "node --test --expose-gc out/test/**/*.test.js"
  },
  "dependencies": {
    "@futuremachine/core": "0.1.0"
  }
}
