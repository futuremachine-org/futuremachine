{
  "name": "futuremachine",
  "author": "Nathan Memmott <nathanmemmott@gmail.com>",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "eslint . --max-warnings 0 && tsc -b",
    "test": "npm test --workspace=@futuremachine/core --workspace=@futuremachine/node-sqlite",
    "test:coverage": "c8 npm run test",
    "test:core": "cd packages/core && npm run test",
    "test:node-sqlite": "cd packages/core && npm run test",
    "test:fuzzer": "cd packages/fuzzer && npm run fuzz",
    "format": "prettier --write .",
    "clean": "tsc -b --clean",
    "prepare": "npm run build && husky",
    "check:circular": "npx madge --circular --extensions ts,tsx packages/",
    "check:versions": "syncpack lint",
    "check:worktree-clean": "test -z \"$(git status --porcelain)\" || (echo 'Error: Working tree is dirty. Commit your changes before shipping.' && exit 1)",
    "pre-ship": "npm run check:worktree-clean -s && npm run clean && npm run build && npm run test",
    "ship:core": "npm run pre-ship && cd packages/core && npm publish --access public",
    "ship:node-sqlite": "npm run pre-ship && cd packages/node-sqlite && npm publish --access public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "syncpack": "^14.3.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "c8": {
    "reporter": [
      "lcov",
      "text"
    ],
    "exclude": [
      "**/test/**"
    ]
  },
  "madge": {
    "detectiveOptions": {
      "ts": {
        "skipTypeImports": true
      },
      "tsx": {
        "skipTypeImports": true
      }
    },
    "excludeRegExp": [
      "\\.stryker-tmp",
      "node_modules",
      "\\out/"
    ]
  }
}
